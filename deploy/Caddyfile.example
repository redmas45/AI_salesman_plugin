# Replace `your-domain.com` with the domain/subdomain whose A record points to
# your static public IP. Browsers require HTTPS for customer microphone access.

your-domain.com {
	encode gzip zstd

	# run.py exposes only the storefront publicly. The storefront wrapper
	# proxies /health, /shopbot.js, and /v1/* to the private backend.
	reverse_proxy 127.0.0.1:8000
}

# Router/DNS checklist:
# - A record: your-domain.com -> 103.97.243.133
# - Router forward TCP 80  -> 192.168.68.71:80
# - Router forward TCP 443 -> 192.168.68.71:443
