# ── OpenAI API ─────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here


# ── Model Selection ───────────────────────────────────────
STT_MODEL=gpt-4o-mini-transcribe
# Leave blank for auto-detect. Set to en, hi, etc. only when you want to force one language.
STT_LANGUAGE=en
LLM_MODEL=gpt-4.1
TTS_MODEL=gpt-4o-mini-tts
TTS_VOICE=alloy

# ── RAG Settings ─────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_TOP_K=10
RAG_TOP_N=3

# ── LLM Settings ─────────────────────────────────────────
LLM_TEMPERATURE=0.30
LLM_MAX_TOKENS=1024

# ── Server ────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=*

# ── Paths ────────────────────────────────────────────────
DATABASE_URL=postgresql://shopbot:shopbot_password@localhost:5433/shopping_db

# ── Shopify Integration ──────────────────────────────────
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_1234567890abcdef
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=

# ── HuggingFace (suppresses symlink warning on Windows) ──
HF_HUB_DISABLE_SYMLINKS_WARNING=1

# Generic website integration
WEBSITE_API_URL=
WEBSITE_API_METHOD=GET
WEBSITE_API_HEADERS_JSON=
WEBSITE_CRAWL_URL=https://example-site.com
WEBSITE_CRAWL_MAX_PAGES=60
WEBSITE_CRAWL_MAX_DEPTH=3
VOICE_ORB_SITE_ID=
VOICE_ORB_API_URL=
SHOPIFY_CRAWL_FALLBACK_URL=




